// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(BUSINESS_OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  businesses    Business[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  BUSINESS_OWNER
  STAFF
}

// ============================================
// BUSINESS (Multi-tenant)
// ============================================

model Business {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL: /peluqueria-juan
  description String?  @db.Text
  logo        String?
  businessType String  @default("store") // store, barbershop, salon, spa, gym, sports, medical, restaurant, other
  phone       String?
  email       String?
  address     String?
  timezone    String   @default("America/Argentina/Buenos_Aires")
  isActive    Boolean  @default(true)
  allowMultipleBookings Boolean @default(false) // Si false, solo 1 turno activo por email
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownerId     String
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services    Service[]
  staff       Staff[]
  appointments Appointment[]
  schedules   BusinessSchedule[]
  subscription Subscription?

  @@map("businesses")
}

model BusinessSchedule {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int      // 0 = Domingo, 1 = Lunes, etc.
  openTime   String   // "09:00"
  closeTime  String   // "18:00"
  isOpen     Boolean  @default(true)

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("business_schedules")
}

// ============================================
// SERVICES
// ============================================

model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?  @db.Text
  duration    Int      // Duración en minutos
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

// ============================================
// STAFF (Empleados)
// ============================================

model Staff {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  email       String?
  phone       String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  schedules    StaffSchedule[]

  @@map("staff")
}

model StaffSchedule {
  id        String  @id @default(cuid())
  staffId   String
  dayOfWeek Int     // 0 = Domingo, 1 = Lunes, etc.
  startTime String  // "09:00"
  endTime   String  // "18:00"
  isWorking Boolean @default(true)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("staff_schedules")
}

// ============================================
// APPOINTMENTS (Turnos)
// ============================================

model Appointment {
  id           String            @id @default(cuid())
  businessId   String
  serviceId    String
  staffId      String?
  
  // Cliente (puede no estar registrado)
  customerName  String
  customerEmail String
  customerPhone String?
  
  // Fecha y hora
  date         DateTime          @db.Date
  startTime    String            // "10:00"
  endTime      String            // "10:30"
  
  status       AppointmentStatus @default(PENDING)
  notes        String?           @db.Text
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ============================================
// SUBSCRIPTIONS (Planes)
// ============================================

model Subscription {
  id                    String             @id @default(cuid())
  businessId            String             @unique
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  
  // Mercado Pago
  mpCustomerId          String?            // ID del cliente en MP
  mpSubscriptionId      String?            // ID de la suscripción en MP
  mpPreapprovalId       String?            // ID del preapproval plan
  
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE  // Gratuito: 150 reservas/mes, 1 staff
  PRO   // Profesional: $15.000/mes, ilimitado
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  link        String?          // URL para navegar al hacer click
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  NEW_APPOINTMENT
  APPOINTMENT_CANCELLED
  APPOINTMENT_CONFIRMED
  REMINDER
}
